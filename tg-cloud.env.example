# TG Cloud lokal/preview test ortam değişkenleri örneği
# Bu dosya örnektir. Gerçek değerleri buraya yazıp commitleme.
# Gerçek kullanım için lokal ortamda .env.local veya terminal export kullan.

# Lokal wrangler dev için varsayılan:
TG_CLOUD_WORKER_URL=http://localhost:8787

# Telegram webhook secret: Cloudflare Worker secret ile aynı olmalı.
TELEGRAM_WEBHOOK_SECRET=BURAYA_GERCEK_DEGER_YAZMA

# Queue okuma secret: Cloudflare Worker secret ile aynı olmalı.
QUEUE_READ_SECRET=BURAYA_GERCEK_DEGER_YAZMA

# Test fixture yolu
TG_CLOUD_FIXTURE=fixtures/tg-cloud-sample-update.json
